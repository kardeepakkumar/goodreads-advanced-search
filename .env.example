# ============================================================
# .env.example — committed template for required secrets
# Copy to .env.local for local development.
# Never commit .env.local or any real secret values.
# In Vercel: set these as Environment Variables in the dashboard.
# ============================================================

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/goodreadsBooks
MONGODB_URI=

# Admin login credentials
ADMIN_USERNAME=admin
# bcrypt hash of admin password, base64-encoded
# Generate: node -e "const b=require('bcryptjs'); b.hash('yourpassword',10).then(h=>console.log(Buffer.from(h).toString('base64')))"
ADMIN_PASSWORD_HASH_B64=

# iron-session encryption secret — must be at least 32 random characters
# Generate: openssl rand -hex 32
IRON_SESSION_SECRET=
